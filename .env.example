# PostgreSQL connection.
# Локальная разработка (docker-compose):
DATABASE_URL=postgres://karman:karman@localhost:5432/karman_db
# Прод (сервер, unix-socket): postgres:///karman_db?host=/var/run/postgresql

# Секрет подписи сессий (JWT, HS256). ОБЯЗАТЕЛЕН в production — иначе сервис не стартует.
# Сгенерировать: openssl rand -base64 48
SESSION_SECRET=change-me-in-production

# node env (development | production)
NODE_ENV=development

# Каталог хранения сканов документов (front_image/back_image/additional_files).
# Абсолютный путь; по умолчанию — `<cwd>/media` (на проде cwd = корень репо,
# каталог gitignored и переживает деплой). Файлы отдаются только через
# авторизованный /api/documents/[id]/file/[slot].
# MEDIA_ROOT=/home/valstan/karman/media

# Мастер-ключ менеджера секретов (AES-256-GCM). base64 от 32 байт.
# Сгенерировать: openssl rand -base64 32
# Хранится ТОЛЬКО в окружении сервера (никогда в БД/репо). Без него страница
# /secrets работает для создания проектов, но шифрование/выдача секретов отключены.
# Потеря ключа = невозможность расшифровать уже сохранённые секреты. См. docs/secrets-manager.md.
# SECRETS_MASTER_KEY=change-me-base64-32-bytes
