server {
    listen 80;
    server_name localhost 4ce93c2b59f9.vps.myjino.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name localhost 4ce93c2b59f9.vps.myjino.ru;

    ssl_certificate /etc/letsencrypt/live/4ce93c2b59f9.vps.myjino.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/4ce93c2b59f9.vps.myjino.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    access_log /var/log/nginx/karman_access.log;
    error_log /var/log/nginx/karman_error.log;

    client_max_body_size 100M;

    location /static/ {
        alias /home/valstan/karman/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /media/ {
        alias /home/valstan/karman/media/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location = / {
        root /home/valstan/karman/frontend_dist;
        try_files /index.html =404;
    }

    location = /app {
        return 301 /app/;
    }

    location /app/ {
        alias /home/valstan/karman/frontend_dist/;
        try_files $uri $uri/ /app/index.html;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
    }

    location /dev/ {
        proxy_pass http://127.0.0.1:3000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
