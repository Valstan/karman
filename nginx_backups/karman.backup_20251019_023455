server {
    server_name 4ce93c2b59f9.vps.myjino.ru;

    # Статические файлы
    location /static/ {
        alias /home/valstan/karman/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Медиа файлы
    location /media/ {
        alias /home/valstan/karman/media/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Проксирование на Django
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        
        # Таймауты
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Логи
    access_log /var/log/nginx/karman_access.log;
    error_log /var/log/nginx/karman_error.log;

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/4ce93c2b59f9.vps.myjino.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/4ce93c2b59f9.vps.myjino.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    listen 80;
    server_name 4ce93c2b59f9.vps.myjino.ru;
    
    # Проверяем, пришел ли запрос через HTTPS прокси
    if ($http_x_forwarded_proto = "https") {
        # Запрос уже через HTTPS, обрабатываем нормально
        set $https_redirect 0;
    }
    
    # Если запрос НЕ через HTTPS прокси, редиректим
    if ($https_redirect != 0) {
        return 301 https://$host$request_uri;
    }
    
    # Статические файлы
    location /static/ {
        alias /home/valstan/karman/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Медиа файлы
    location /media/ {
        alias /home/valstan/karman/media/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Проксирование на Django
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        
        # Таймауты
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Логи
    access_log /var/log/nginx/karman_access.log;
    error_log /var/log/nginx/karman_error.log;
}
