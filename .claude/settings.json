{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git fetch*)",
      "Bash(git pull --ff-only*)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff*)",
      "Bash(git stash list*)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push -u origin chore/*)",
      "Bash(git push -u origin docs/*)",
      "Bash(git push -u origin refactor/*)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin chore/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin refactor/*)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(npm ci*)",
      "Bash(npx vitest run*)",
      "Bash(bash scripts/git_sync_check.sh*)",
      "Bash(bash scripts/deploy_remote.sh*)",
      "PowerShell(git status*)",
      "PowerShell(git log *)",
      "PowerShell(git diff*)",
      "PowerShell(git fetch*)",
      "PowerShell(git pull --ff-only*)",
      "PowerShell(npm run typecheck*)",
      "PowerShell(npm run test*)",
      "PowerShell(npm run build*)",
      "PowerShell(gh pr view *)",
      "PowerShell(gh pr list*)",
      "PowerShell(gh pr checks*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -u origin main*)",
      "Bash(git push origin main*)",
      "Bash(git push -u origin master*)",
      "Bash(git push origin master*)",
      "Bash(gh pr merge --admin*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",
      "PowerShell(git push -u origin main*)",
      "PowerShell(git push origin main*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/git_sync_check.sh\" --warn"
          }
        ]
      }
    ]
  }
}
